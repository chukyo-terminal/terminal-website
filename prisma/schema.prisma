generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sudoer {
  id        Int      @id @default(autoincrement())
  cuId      String   @unique @map("cu_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation("UserToSudoer", fields: [cuId], references: [cuId])

  @@map("sudoers")
}

enum Role {
  ADMIN
  REVIEWER
  CONTRIBUTOR
}

model User {
  id          Int      @id @default(autoincrement())
  cuId        String   @unique @map("cu_id")
  name        String
  displayName String?  @unique @map("display_name")
  roles       Role[]   @default([])
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  sudoer Sudoer? @relation("UserToSudoer")

  @@map("users")
}
